{
  "name": "clearschema",
  "displayName": "ClearSchema",
  "description": "Syntax highlighting and language support for ClearSchema - a human-friendly schema language",
  "version": "0.2.0",
  "publisher": "clearschema",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:clearschema"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w"
  },
  "contributes": {
    "languages": [
      {
        "id": "clearschema",
        "aliases": [
          "ClearSchema",
          "clearschema"
        ],
        "extensions": [
          ".clear"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "clearschema",
        "scopeName": "source.clearschema",
        "path": "./syntaxes/clearschema.tmLanguage.json"
      }
    ]
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.9.0"
  }
}
